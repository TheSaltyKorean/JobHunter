{
  "manifest_version": 3,
  "name": "JobHunter — Application Tracker & Autofill",
  "version": "1.0.0",
  "description": "Save jobs, auto-fill applications, and track every stage of your job search — across LinkedIn, Indeed, Workday, Greenhouse, Lever, and more.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "JobHunter"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Alt+J",
        "mac": "Alt+J"
      },
      "description": "Toggle JobHunter sidebar"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html", "resumes/*.pdf"],
      "matches": ["<all_urls>"]
    }
  ]
}
